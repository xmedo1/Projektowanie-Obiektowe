<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>Edytuj kategorię</title>
</head>
<body style="font-family: sans-serif; padding: 20px;">
    <h1>Edytuj Kategorię</h1>
    
    <form method="POST" action="/web/categories/#(category.id)/edit">
        <label>Nazwa Kategorii:</label><br>
        <input type="text" name="name" value="#(category.name)" required><br><br>
        <button type="submit">Zapisz zmiany</button>
    </form>
    
    <br>
    <a href="/web/categories">Wróć do list</a>
</body>
</html>