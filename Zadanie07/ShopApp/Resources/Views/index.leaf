<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">

  <title>Sklep</title>
</head>

<body>
  <h1>Lista produktów</h1>
    
    <table border="1" cellpadding="10" style="border-collapse: collapse; margin-bottom: 20px;">
        <tr>
            <th>Nazwa</th>
            <th>Cena</th>
            <th>Akcje</th>
        </tr>
        #for(product in products):
        <tr>
            <td>#(product.name)</td>
            <td>#(product.price) zł</td>
            <td>
                <a href="/web/products/#(product.id)/edit">Edytuj</a>
                
                <form method="POST" action="/web/products/#(product.id)/delete" style="display:inline;">
                    <button type="submit" style="color: red;">Usuń</button>
                </form>
            </td>
        </tr>
        #endfor
    </table>

    <h2>Dodaj nowy produkt</h2>
    <form method="POST" action="/web/products">
        <input type="text" name="name" placeholder="Nazwa produktu" required>
        <input type="number" step="0.01" name="price" placeholder="Cena" required>
        <button type="submit">Dodaj</button>
    </form>
</body>
</html>